{
  "name": "authorization-server",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc && node scripts/generate-swagger.js",
    "generate-swagger": "node scripts/generate-swagger.js",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/db/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/db/data-source.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "reflect-metadata": "^0.2.1",
    "sqlite3": "^5.0.3",
    "typeorm": "^0.3.19",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/ws": "^8.5.10",
    "@vitest/ui": "^4.1.2",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2",
    "zod-to-json-schema": "^3.25.2"
  }
}
